{
  "name": "@luu-truong/react-native-reaction-button",
  "version": "2.0.4",
  "description": "Reactions like Facebook does",
  "main": "lib/commonjs/index.js",
  "module": "lib/module/index.js",
  "types": "lib/typescript/src/index.d.ts",
