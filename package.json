  "scripts": {
    "build": "bob build",
    "prettier": "prettier --write ./src",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": ">=18.3.0",
    "react-native": ">=0.76.0",
    "react-native-gesture-handler": ">=2.20.0",
    "react-native-reanimated": ">=3.16.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "prettier": "^3.3.3",
    "react": "18.3.1",
    "react-native": "0.76.0",
    "react-native-builder-bob": "^0.32.0",
    "react-native-gesture-handler": "^2.20.0",
    "react-native-reanimated": "^3.16.0",
    "typescript": "^5.4.5"
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      "commonjs",
